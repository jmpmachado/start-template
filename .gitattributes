# Normalise all text files to LF on commit, checkout as-is on all platforms.
* text=auto eol=lf

# Explicitly binary — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.gz binary
*.tar binary

# Lock files — treat as text but never normalise (preserves npm/yarn reproducibility).
package-lock.json text eol=lf
yarn.lock         text eol=lf
