# Environment Configuration — [PROJECT_NAME]
#
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# All variables marked [REQUIRED] must be set before the application starts.
# Variables marked [OPTIONAL] have safe defaults for development.
#
# Security note: rotate any secret that has been exposed (seen in logs, shared over chat, etc.)

# =============================================================================
# Application
# =============================================================================

# Application environment: development | staging | production
# [REQUIRED]
NODE_ENV=development

# Port the HTTP server listens on
# [OPTIONAL] default: 3000
PORT=3000

# Base URL for the application (used in emails, redirects, CORS)
# [REQUIRED in staging/production]
APP_URL=http://localhost:3000

# =============================================================================
# Authentication
# =============================================================================

# Secret used to sign JWT tokens. Must be >= 256 bits (32+ random bytes).
# Generate (ESM-compatible): node --input-type=module -e "import {randomBytes} from 'crypto'; console.log(randomBytes(32).toString('hex'))"
# [REQUIRED]
JWT_SECRET=

# JWT access token TTL (e.g., 15m, 1h)
# [OPTIONAL] default: 15m
JWT_EXPIRES_IN=15m

# JWT refresh token TTL (e.g., 7d, 30d)
# [OPTIONAL] default: 7d
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# Database
# =============================================================================

# Primary database connection string
# Format depends on driver: postgres://user:pass@host:5432/dbname
# [REQUIRED]
DATABASE_URL=

# Maximum number of connections in the pool
# [OPTIONAL] default: 10
DATABASE_POOL_MAX=10

# Run database migrations automatically on startup: true | false
# [OPTIONAL] default: false (run manually in production)
DATABASE_AUTO_MIGRATE=false

# =============================================================================
# Cache
# =============================================================================

# Redis / cache connection URL
# [OPTIONAL] — leave empty to use in-memory fallback (not suitable for production)
REDIS_URL=

# Cache TTL in seconds for session data
# [OPTIONAL] default: 3600
CACHE_SESSION_TTL=3600

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per window per IP
# [OPTIONAL] default: 100
RATE_LIMIT_MAX=100

# Auth endpoints rate limit (stricter) — see THREAT_MODEL.md §3.1
# [OPTIONAL] default: 5
RATE_LIMIT_AUTH_MAX=5

# Rate limit window in milliseconds
# [OPTIONAL] default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# External Services
# =============================================================================

# Example: Email service
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@[project].example.com

# Example: Object storage
# STORAGE_BUCKET=
# STORAGE_REGION=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=

# =============================================================================
# Observability
# =============================================================================

# Log level: error | warn | info | debug
# [OPTIONAL] default: info
LOG_LEVEL=info

# Enable Prometheus metrics endpoint: true | false
# [OPTIONAL] default: false
METRICS_ENABLED=false

# Metrics endpoint path (requires METRICS_ENABLED=true)
# [OPTIONAL] default: /metrics
METRICS_PATH=/metrics

# =============================================================================
# Security
# =============================================================================

# Comma-separated list of allowed CORS origins
# [REQUIRED in staging/production] — use * only in development
CORS_ORIGINS=http://localhost:3000

# Enable HTTPS redirect in production: true | false
# [OPTIONAL] default: false
FORCE_HTTPS=false

# =============================================================================
# Feature Flags
# =============================================================================

# Template: add project-specific feature flags here
# FEATURE_[NAME]=false

# =============================================================================
# Publishing Guard
# =============================================================================
# package.json has "private": true — this prevents accidental npm publish.
# Remove "private": true ONLY when intentionally publishing a package.
# Before any publish: run 'npm publish --dry-run' to verify scoped name (@org/pkg).
# See SECURITY.md §3 for token TTL rationale (JWT_EXPIRES_IN, JWT_REFRESH_EXPIRES_IN).
