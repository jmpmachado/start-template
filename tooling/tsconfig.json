{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "types": ["node", "vitest/globals"],
    "typeRoots": ["./node_modules/@types", "./node_modules"]
  },
  "include": ["../src/**/*", "../tests/**/*", "../scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
